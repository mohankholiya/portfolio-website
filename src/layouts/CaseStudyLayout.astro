---
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Mohan Kholiya</title>

    <!-- Fonts for case studies -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- View Transitions -->
    <ClientRouter />

    <style is:global>
      *{box-sizing:border-box;}
      html{-webkit-text-size-adjust:100%;}
      body{margin:0;background:#F6F8FA;color:#16222E;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;font-size:16px;line-height:1.6;}
      .wrap{max-width:840px;margin:0 auto;padding:40px 24px 80px;}
      .nav{padding:16px 24px;background:#0C2438;border-bottom:1px solid #D7DEE4;}
      .nav a{color:#7FA8C9;text-decoration:none;font-family:"IBM Plex Mono",monospace;font-size:12px;letter-spacing:.14em;transition:color 0.2s;}
      .nav a:hover{color:#fff;}

      h1{font-family:"Archivo",sans-serif;font-weight:700;font-size:28px;color:#0C2438;margin:32px 0 16px;line-height:1.2;}
      h2{font-family:"Archivo",sans-serif;font-weight:700;font-size:20px;color:#10314c;margin:32px 0 12px;}
      h3{font-family:"Archivo",sans-serif;font-weight:600;font-size:17px;color:#10314c;margin:24px 0 8px;}
      h4{font-family:"Archivo",sans-serif;font-size:15px;color:#10314c;margin:16px 0 6px;font-weight:600;}
      p{margin:0 0 16px;color:#3A4751;line-height:1.7;}
      ul{margin:0 0 16px;padding-left:20px;color:#3A4751;}
      li{margin-bottom:8px;}
      ol{margin:0 0 16px;padding-left:20px;color:#3A4751;}
      ol li{margin-bottom:12px;}

      .cs-spec{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#D7DEE4;border:1px solid #D7DEE4;border-radius:10px;overflow:hidden;margin:20px 0 10px;}
      .cs-spec>div{background:#fff;padding:16px;}
      .cs-spec .k{font-family:"IBM Plex Mono",monospace;font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:#8295A3;margin:0 0 5px;}
      .cs-spec .v{font-family:"Archivo",sans-serif;font-weight:600;font-size:13px;color:#10314c;line-height:1.3;}
      @media(max-width:640px){.cs-spec{grid-template-columns:1fr 1fr;}}

      .cs-chart{background:#fff;border:1px solid #D7DEE4;border-radius:10px;padding:22px 20px 16px;margin:22px 0;}
      .cs-chart .ct{font-family:"Archivo",sans-serif;font-weight:700;font-size:15px;color:#0C2438;margin:0 0 2px;}
      .cs-chart .cd{font-size:13px;color:#5E6E7B;margin:0 0 12px;}
      .cs-chart svg{width:100%;height:auto;display:block;}
      .cs-sowhat{font-size:14px;color:#3A4751;margin:12px 2px 0;padding-top:12px;border-top:1px solid #D7DEE4;}
      .cs-sowhat b{color:#8A4E18;}

      .cs-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#D7DEE4;border:1px solid #D7DEE4;border-radius:10px;overflow:hidden;margin:20px 0;}
      .cs-cards>div{background:#fff;padding:20px 18px;}
      .cs-cards .m{font-family:"IBM Plex Mono",monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:#C2772F;margin:0 0 8px;}
      .cs-cards h4{font-family:"Archivo",sans-serif;font-size:15px;color:#10314c;margin:0 0 7px;}
      .cs-cards p{font-size:13.5px;color:#3A4751;margin:0;}
      @media(max-width:680px){.cs-cards{grid-template-columns:1fr;}}

      .cs-closing{background:#0C2438;color:#EAF0F5;border-radius:12px;padding:28px 26px;margin:20px 0;}
      .cs-closing p{margin:0;font-family:"Archivo",sans-serif;font-weight:500;font-size:18px;line-height:1.4;color:#fff;}
      .cs-note{font-size:12px;color:#5E6E7B;margin-top:18px;}

      .result-list{list-style:none;padding:0;margin:0 0 20px;}
      .result-list li{margin-bottom:14px;padding-left:24px;position:relative;color:#3A4751;line-height:1.6;}
      .result-list li::before{content:"•";position:absolute;left:0;color:#C2772F;font-size:18px;font-weight:700;}

      @media(max-width:600px){
        .wrap{padding:20px 16px 60px;}
        h1{font-size:22px;}
        h2{font-size:17px;}
        .cs-chart{padding:16px 12px 12px;}
      }

      strong{color:#10314c;font-weight:600;}
    </style>
  </head>
  <body>
    <nav class="nav">
      <a href="/" target="_self">&larr; Back to Portfolio</a>
    </nav>
    <div class="wrap">
      <slot />
    </div>

    <!-- If a visitor enters on a case study first, still hide the home page's
         first-visit loader when they navigate back via a view-transition swap. -->
    <script is:inline>
      document.addEventListener('astro:after-swap', function () {
        var l = document.getElementById('page-loader');
        if (l) l.style.display = 'none';
      });
    </script>
  </body>
</html>
