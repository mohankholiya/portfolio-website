---
import { credentials } from "../content/site";

const colDotColors = ["var(--color-link)", "#f97316", "var(--color-success)"];
---

<section
  id="credentials"
  aria-labelledby="credentials-heading"
  class="section"
  style="background:var(--color-canvas);"
>
  <div class="container">

    <!-- Header -->
    <div style="max-width:560px; margin-bottom:48px;">
      <p class="t-caption-mono reveal" style="
        color:var(--color-mute);
        text-transform:uppercase;
        letter-spacing:0.08em;
        margin:0 0 16px;
      ">Credentials</p>

      <h2 id="credentials-heading" class="t-display-lg reveal" style="
        color:var(--color-ink); margin:0;
        animation-delay:0.07s;
      ">
        Education, certifications, and career footprint.
      </h2>
    </div>

    <!-- Three-column grid -->
    <div style="
      display:grid;
      grid-template-columns:repeat(auto-fill, minmax(min(100%, 300px), 1fr));
      gap:32px;
    " class="credentials-grid">
      {credentials.map((col, ci) => (
        <div class="reveal" style={`animation-delay:${ci * 0.1 + 0.2}s;`}>
          <!-- Column heading with icon -->
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:24px;">
            <span aria-hidden="true" style={`
              width:16px; height:16px;
              border-radius:50%;
              background:${colDotColors[ci]};
              opacity:0.7;
              flex-shrink:0;
            `}></span>
            <h3 class="t-caption-mono" style="
              color:var(--color-mute);
              text-transform:uppercase;
              letter-spacing:0.08em;
              margin:0;
            ">{col.category}</h3>
          </div>

          <!-- Timeline entries -->
          <div style="display:flex; flex-direction:column; gap:20px;">
            {col.entries.map(entry => (
              <div style="position:relative; padding-left:24px; border-left:2px solid rgba(255,255,255,0.08);">
                <!-- Timeline dot -->
                <span aria-hidden="true" style={`
                  position:absolute;
                  left:-5px; top:4px;
                  width:8px; height:8px;
                  border-radius:50%;
                  background:${colDotColors[ci]};
                  flex-shrink:0;
                `}></span>
                <p class="t-body-sm-strong" style="color:var(--color-ink); margin:0 0 6px;">{entry.title}</p>
                {entry.body && (
                  <p class="t-body-sm" style="color:var(--color-body-text); margin:0; line-height:1.6;">
                    {entry.body}
                  </p>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Expert network callout -->
    <div
      class="reveal shadow-l2"
      style="
        display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:16px;
        background:var(--color-canvas-soft-2);
        border-radius:var(--radius-md);
        padding:24px 32px;
        margin-top:40px;
        animation-delay:0.4s;
        border:1px solid rgba(255,255,255,0.05);
        text-align:left;
      "
    >
      <div style="display:flex; align-items:flex-start; gap:16px;">
        <div style="
          width:40px; height:40px;
          border-radius:var(--radius-sm);
          background:rgba(77,158,255,0.1);
          display:flex; align-items:center; justify-content:center;
          flex-shrink:0;
        " aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-link)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.29-1.29a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
        </div>
        <div>
          <p class="t-body-sm-strong" style="color:var(--color-ink); margin:0 0 4px;">
            Available for expert network calls
          </p>
          <p class="t-body-sm" style="color:var(--color-body-text); margin:0;">
            Energy, utilities, and procurement strategy — happy to take calls via expert network platforms.
          </p>
        </div>
      </div>
      <a
        href="mailto:mohan.kholiya@gmail.com?subject=Expert%20network%20enquiry"
        class="btn-secondary-sm t-button-sm"
        style="flex-shrink:0;"
      >
        Get in touch
      </a>
    </div>

  </div>
</section>

<style>
  @media (min-width: 960px) {
    .credentials-grid {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }
</style>
