---
import { credentials } from "../content/site";
---

<section
  id="credentials"
  aria-labelledby="credentials-heading"
  class="section"
  style="background:var(--color-paper);"
>
  <div class="container">

    <!-- Header -->
    <div class="reveal" style="max-width:600px; margin-bottom:40px;">
      <div class="section-eyebrow">
        <p class="t-eyebrow" style="margin:0;">Credentials</p>
      </div>

      <h2 id="credentials-heading" class="t-display-lg" style="margin:0 0 14px; animation-delay:0.07s;">
        Education, certifications, and recognition.
      </h2>
    </div>

    <!-- Three-column grid -->
    <div class="reveal credentials-grid" style="animation-delay:0.12s;">
      {credentials.map((col, ci) => (
        <div class="cred-col">
          <h3 class="cred-col__head">
            <span class="cred-col__index" aria-hidden="true">0{ci + 1}</span>
            {col.category}
          </h3>

          <div class="cred-entries">
            {col.entries.map(entry => (
              <div class="cred-entry">
                <span class="cred-node" aria-hidden="true"></span>
                <p class="cred-entry__title">{entry.title}</p>
                {entry.body && <p class="cred-entry__body">{entry.body}</p>}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Expert network callout -->
    <div class="reveal cred-callout" style="animation-delay:0.28s;">
      <div class="cred-callout__text">
        <p class="cred-callout__title">Available for expert-network calls</p>
        <p class="cred-callout__body">
          Energy, utilities, and procurement strategy &mdash; happy to take calls via
          leading expert-network platforms.
        </p>
      </div>
      <a
        href="mailto:mohan.kholiya@gmail.com?subject=Expert%20network%20enquiry"
        class="btn-secondary-sm t-button-sm"
      >
        Request a call
      </a>
    </div>

  </div>
</section>

<style>
  .credentials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    margin-bottom: 40px;
  }
  @media (min-width: 760px) { .credentials-grid { grid-template-columns: repeat(3, 1fr); gap: 40px; } }

  .cred-col__head {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-faint);
    margin: 0 0 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-hairline);
  }
  .cred-col__index { color: var(--color-accent); }

  .cred-entries { display: flex; flex-direction: column; gap: 22px; }
  .cred-entry {
    position: relative;
    padding-left: 20px;
    border-left: 1px solid var(--color-hairline-soft);
  }
  .cred-node {
    position: absolute;
    left: -4px; top: 6px;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-paper);
  }
  .cred-entry__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14.5px;
    line-height: 1.35;
    color: var(--color-ink);
    margin: 0 0 5px;
  }
  .cred-entry__body {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--color-body);
    margin: 0;
  }

  .cred-callout {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    background: var(--color-ink);
    color: var(--color-on-ink);
    border-radius: var(--radius-lg);
    padding: 24px 28px;
  }
  .cred-callout__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    margin: 0 0 4px;
    color: #fff;
  }
  .cred-callout__body { font-size: 14px; margin: 0; color: #B9C7D4; line-height: 1.55; }
  .cred-callout :global(.btn-secondary-sm) {
    background: rgba(255,255,255,0.06);
    color: #fff;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.22);
  }
  .cred-callout :global(.btn-secondary-sm):hover { background: rgba(255,255,255,0.12); }
</style>
