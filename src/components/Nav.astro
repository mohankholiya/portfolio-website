---
import { siteConfig } from "../content/site";
---

<nav id="site-nav" aria-label="Main navigation">
  <div class="container" style="display:flex; align-items:center; justify-content:space-between; height:64px; padding:0 24px;">

    <!-- Logo -->
    <a href="/" aria-label="Mohan Kholiya — home" style="display:flex; align-items:center; gap:8px; text-decoration:none; flex-shrink:0;">
      <span style="
        width:32px; height:32px;
        background:var(--color-ink); color:var(--color-on-ink);
        border-radius:var(--radius-sm);
        display:flex; align-items:center; justify-content:center;
        font-size:13px; font-weight:600; letter-spacing:-0.5px;
        flex-shrink:0;
      " aria-hidden="true">MK</span>
      <span class="t-body-sm-strong nav-name" style="color:var(--color-ink);">Mohan Kholiya</span>
    </a>

    <!-- Desktop nav links -->
    <ul class="nav-links" style="
      display:flex; align-items:center; gap:4px;
      list-style:none; margin:0; padding:0;
    ">
      {[
        { href: "#about",         label: "About" },
        { href: "#case-studies",  label: "Case Studies" },
        { href: "#competencies",  label: "Competencies" },
        { href: "#credentials",   label: "Credentials" },
        { href: "#contact",       label: "Contact" },
      ].map(link => (
        <li>
          <a
            href={link.href}
            class="t-body-sm"
            style="
              color:var(--color-body-text);
              text-decoration:none;
              padding:6px 12px;
              border-radius:var(--radius-full);
              transition:background 0.15s ease, color 0.15s ease;
              display:block;
            "
            onmouseover="this.style.background='var(--color-canvas-soft-2)'; this.style.color='var(--color-ink)';"
            onmouseout="this.style.background=''; this.style.color='var(--color-body-text)';"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTAs -->
    <div class="nav-ctas" style="display:flex; align-items:center; gap:8px; flex-shrink:0;">
      <a
        href={siteConfig.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary-sm t-button-sm"
        aria-label="LinkedIn profile"
      >
        LinkedIn
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M1.5 1.5h7m0 0v7m0-7L1.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href={siteConfig.resumeUrl}
        download="Mohan_Kholiya_Resume.pdf"
        class="btn-secondary-sm t-button-sm"
        aria-label="Download résumé PDF"
      >
        Résumé
      </a>
      <a
        href={`mailto:${siteConfig.email}`}
        class="btn-primary-sm t-button-sm"
      >
        Email Mohan
      </a>
    </div>

    <!-- Hamburger (mobile) -->
    <button
      id="nav-hamburger"
      class="hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      style="
        display:none;
        background:none; border:none; cursor:pointer;
        padding:8px; color:var(--color-ink);
        border-radius:var(--radius-sm);
      "
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path id="menu-icon" d="M2 5h16M2 10h16M2 15h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile overlay menu -->
  <div
    id="mobile-menu"
    aria-label="Mobile navigation"
    style="
      display:none;
      position:fixed; inset:0; top:64px;
      background:rgba(255,255,255,0.97);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
      z-index:99;
      padding:24px;
      flex-direction:column;
      gap:4px;
    "
  >
    {[
      { href: "#about",         label: "About" },
      { href: "#case-studies",  label: "Case Studies" },
      { href: "#competencies",  label: "Competencies" },
      { href: "#credentials",   label: "Credentials" },
      { href: "#contact",       label: "Contact" },
    ].map(link => (
      <a
        href={link.href}
        class="mobile-nav-link t-display-sm"
        style="
          color:var(--color-ink);
          text-decoration:none;
          padding:16px 0;
          border-bottom:1px solid var(--color-hairline);
          display:block;
          transition:color 0.15s ease;
        "
      >
        {link.label}
      </a>
    ))}
    <div style="display:flex; flex-direction:column; gap:8px; margin-top:24px;">
      <a href={`mailto:${siteConfig.email}`} class="btn-primary t-button-lg" style="justify-content:center;">Email Mohan</a>
      <a href={siteConfig.resumeUrl} download class="btn-secondary t-button-lg" style="justify-content:center;">Download Résumé</a>
    </div>
  </div>
</nav>

<style>
  @media (max-width: 860px) {
    .nav-links  { display: none !important; }
    .nav-ctas   { display: none !important; }
    .nav-name   { display: none !important; }
    .hamburger  { display: flex !important; }
  }
</style>

<script>
  // Scroll shadow
  const nav = document.getElementById('site-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 8);
  }, { passive: true });

  // Hamburger toggle
  const hamburger = document.getElementById('nav-hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  let menuOpen = false;

  hamburger?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    hamburger.setAttribute('aria-expanded', String(menuOpen));
    if (mobileMenu) {
      mobileMenu.style.display = menuOpen ? 'flex' : 'none';
    }
  });

  // Close on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menuOpen = false;
      hamburger?.setAttribute('aria-expanded', 'false');
      if (mobileMenu) mobileMenu.style.display = 'none';
    });
  });
</script>
