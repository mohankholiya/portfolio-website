---
const testimonials = [
  {
    quote:
      "Mohan brought a level of analytical rigour to our category strategy that we had not seen from previous advisors. His benchmarking work gave us the confidence to challenge supplier pricing and restructure our contracting approach — the savings spoke for themselves.",
    title: "VP Procurement",
    company: "Global E&P Operator",
    initials: "VP",
  },
  {
    quote:
      "What set Mohan apart was his ability to translate complex cost-driver analysis into clear, actionable recommendations. He didn't just identify the problem — he built the roadmap to fix it, and stayed through implementation.",
    title: "Director of Supply Chain",
    company: "UK Energy Utility",
    initials: "DS",
  },
  {
    quote:
      "Mohan's should-cost modelling on our service-delivery contract was incredibly thorough. He identified value levers that our own team had overlooked, and negotiated a renewal that protected service continuity while locking in significant cost optimisation.",
    title: "Head of Procurement",
    company: "Tier-1 Telecom Operator",
    initials: "HP",
  },
];

const [featured, ...rest] = testimonials;
---

<section
  id="testimonials"
  aria-labelledby="testimonials-heading"
  class="section"
  style="background:var(--color-surface-tint); position:relative;"
>
  <div class="container">

    <!-- Header -->
    <div class="reveal" style="max-width:600px; margin-bottom:40px;">
      <div class="section-eyebrow">
        <p class="t-eyebrow" style="margin:0;">Testimonials</p>
      </div>

      <h2 id="testimonials-heading" class="t-display-lg" style="margin:0 0 14px; animation-delay:0.07s;">
        What leaders say.
      </h2>

      <p class="t-body-md" style="margin:0; animation-delay:0.12s;">
        Client endorsements from senior procurement and supply chain leaders across energy,
        utilities, and telecom.
      </p>
    </div>

    <!-- Bento layout -->
    <div class="reveal bento-grid" style="animation-delay:0.16s;">

      <!-- Featured -->
      <figure class="tst tst--featured">
        <span class="tst__quote-mark" aria-hidden="true">&ldquo;</span>
        <blockquote class="tst__quote tst__quote--lg">
          {featured.quote}
        </blockquote>
        <figcaption class="tst__attr">
          <span class="tst__initials" aria-hidden="true">{featured.initials}</span>
          <span>
            <span class="tst__title">{featured.title}</span>
            <span class="tst__company">{featured.company}</span>
          </span>
        </figcaption>
      </figure>

      <!-- Two stacked -->
      <div class="tst-stack">
        {rest.map(t => (
          <figure class="tst">
            <blockquote class="tst__quote">&ldquo;{t.quote}&rdquo;</blockquote>
            <figcaption class="tst__attr">
              <span class="tst__initials tst__initials--sm" aria-hidden="true">{t.initials}</span>
              <span>
                <span class="tst__title">{t.title}</span>
                <span class="tst__company">{t.company}</span>
              </span>
            </figcaption>
          </figure>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .tst {
    background: var(--color-surface);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    padding: 26px 28px;
    margin: 0;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .tst::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--color-accent);
    opacity: 0.5;
  }
  .tst--featured {
    padding: 38px 40px;
    justify-content: space-between;
    min-height: 100%;
  }
  .tst--featured::before { opacity: 0.9; }
  .tst__quote-mark {
    font-family: var(--font-display);
    font-size: 72px;
    line-height: 0.6;
    color: var(--color-accent);
    opacity: 0.28;
    display: block;
    margin-bottom: 6px;
    user-select: none;
  }
  .tst__quote {
    margin: 0;
    flex: 1;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-body);
  }
  .tst__quote--lg { font-size: 18px; line-height: 1.6; color: var(--color-ink); font-weight: 400; }
  .tst-stack { display: flex; flex-direction: column; gap: 16px; }
  .tst__attr {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--color-hairline-soft);
  }
  .tst__initials {
    width: 42px; height: 42px;
    border-radius: 50%;
    background: var(--color-accent-tint);
    color: var(--color-accent-dark);
    box-shadow: inset 0 0 0 1px #E6CDB2;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 700; font-size: 13px;
    flex-shrink: 0;
  }
  .tst__initials--sm { width: 36px; height: 36px; font-size: 11px; }
  .tst__title {
    display: block;
    font-family: var(--font-display);
    font-weight: 600; font-size: 14px;
    color: var(--color-ink);
  }
  .tst__company {
    display: block;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-faint);
    margin-top: 2px;
  }
</style>
