---
interface Props {
  id: string;
  sector: string;
  sectorLabel: string;
  headline: string;
  metric: string;
  metricLabel: string;
  description: string;
  tags: string[];
}

const { id, sector, sectorLabel, headline, metric, metricLabel, description, tags } = Astro.props;

const sectorColor: Record<string, { bg: string; text: string; border: string }> = {
  energy:           { bg: 'rgba(249,115,22,0.12)',  text: '#fb923c', border: 'rgba(249,115,22,0.25)' },
  utilities:        { bg: 'rgba(62,207,142,0.12)',  text: '#3ecf8e', border: 'rgba(62,207,142,0.25)' },
  telecom:          { bg: 'rgba(167,139,250,0.12)', text: '#a78bfa', border: 'rgba(167,139,250,0.25)' },
  'energy-utilities': { bg: 'rgba(77,158,255,0.12)', text: '#4d9eff', border: 'rgba(77,158,255,0.25)' },
};
const color = sectorColor[sector] ?? { bg: 'var(--color-canvas-soft-2)', text: 'var(--color-mute)', border: 'rgba(255,255,255,0.07)' };
---

<a
  href={`/case-studies/${id}/`}
  id={id}
  data-sector={sector}
  class="case-card shadow-l3 reveal"
  style="
    background:var(--color-canvas);
    border-radius:var(--radius-md);
    padding:24px;
    display:flex;
    flex-direction:column;
    gap:16px;
    transition:transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration:none;
    color:inherit;
  "
  onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='inset 0 0 0 1px rgba(255,255,255,0.14), 0px 8px 32px -4px rgba(0,0,0,0.7)';"
  onmouseout="this.style.transform=''; this.style.boxShadow='';"
  target="_blank"
  rel="noopener noreferrer"
>
  <!-- Sector tag -->
  <div>
    <span class="t-caption-mono" style={`
      display:inline-block;
      background:${color.bg};
      color:${color.text};
      border:1px solid ${color.border};
      border-radius:var(--radius-full);
      padding:0 10px;
      height:22px;
      line-height:20px;
      text-transform:uppercase;
      letter-spacing:0.06em;
      font-size:11px;
    `}>{sectorLabel}</span>
  </div>

  <!-- Metric (hero number) -->
  <div>
    <p class="t-display-md" style="color:var(--color-ink); margin:0 0 4px;">{metric}</p>
    <p class="t-caption-mono" style="color:var(--color-mute); margin:0; text-transform:lowercase;">{metricLabel}</p>
  </div>

  <!-- Headline -->
  <h3 class="t-display-sm" style="color:var(--color-ink); margin:0;">{headline}</h3>

  <!-- Divider -->
  <div style="border-top:1px solid var(--color-hairline);"></div>

  <!-- Description -->
  <p class="t-body-sm" style="color:var(--color-body-text); margin:0; flex:1;">{description}</p>

  <!-- Tags -->
  <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:auto;">
    {tags.map(tag => (
      <span class="badge t-caption-mono" style="font-size:11px;">{tag}</span>
    ))}
  </div>
</a>
