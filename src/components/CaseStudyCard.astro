---
interface Props {
  id: string;
  sector: string;
  sectorLabel: string;
  headline: string;
  metric: string;
  metricLabel: string;
  description: string;
  tags: string[];
}

const { id, sector, sectorLabel, headline, metric, metricLabel, description, tags } = Astro.props;

const sectorColor: Record<string, { bg: string; text: string; border: string }> = {
  energy:             { bg: 'rgba(249,115,22,0.12)',  text: '#fb923c', border: 'rgba(249,115,22,0.25)' },
  utilities:          { bg: 'rgba(62,207,142,0.12)',  text: '#3ecf8e', border: 'rgba(62,207,142,0.25)' },
  telecom:            { bg: 'rgba(167,139,250,0.12)', text: '#a78bfa', border: 'rgba(167,139,250,0.25)' },
  'energy-utilities': { bg: 'rgba(77,158,255,0.12)',  text: '#4d9eff', border: 'rgba(77,158,255,0.25)' },
};
const color = sectorColor[sector] ?? { bg: 'var(--color-canvas-soft-2)', text: '#888', border: 'rgba(255,255,255,0.07)' };
---

<a
  href={`/case-studies/${id}/`}
  id={id}
  data-sector={sector}
  class="case-card card-shimmer shadow-l3"
  style={`--glow:${color.text}; background:linear-gradient(180deg, ${color.bg} 0%, var(--color-canvas) 72px); border-radius:var(--radius-md); padding:24px; display:flex; flex-direction:column; gap:16px; text-decoration:none; color:inherit; border-top:1px solid ${color.border};`}
  target="_blank"
  rel="noopener noreferrer"
>
  <!-- Sector tag -->
  <div>
    <span class="t-caption-mono" style={`
      display:inline-block;
      background:${color.bg};
      color:${color.text};
      border:1px solid ${color.border};
      border-radius:var(--radius-full);
      padding:0 10px;
      height:22px;
      line-height:20px;
      text-transform:uppercase;
      letter-spacing:0.06em;
      font-size:11px;
    `}>{sectorLabel}</span>
  </div>

  <!-- Metric (hero number) -->
  <div>
    <p class="t-display-md" style="color:var(--color-ink); margin:0 0 4px;">{metric}</p>
    <p class="t-caption-mono" style="color:var(--color-mute); margin:0; text-transform:lowercase;">{metricLabel}</p>
  </div>

  <!-- Headline -->
  <h3 class="t-display-sm" style="color:var(--color-ink); margin:0;">{headline}</h3>

  <!-- Divider -->
  <div style="border-top:1px solid var(--color-hairline);"></div>

  <!-- Description -->
  <p class="t-body-sm" style="color:var(--color-body-text); margin:0; flex:1;">{description}</p>

  <!-- Tags + read arrow row -->
  <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-top:auto; flex-wrap:wrap;">
    <div style="display:flex; flex-wrap:wrap; gap:6px;">
      {tags.map(tag => (
        <span class="badge t-caption-mono" style="font-size:11px;">{tag}</span>
      ))}
    </div>
    <!-- Read more arrow -->
    <span class="card-arrow" aria-hidden="true" style={`
      display:inline-flex; align-items:center; justify-content:center;
      width:28px; height:28px; border-radius:50%;
      border:1px solid ${color.border};
      color:${color.text};
      flex-shrink:0;
      transition:background 0.2s ease, transform 0.2s ease;
    `}>
      <svg width="12" height="12" viewBox="0 0 10 10" fill="none">
        <path d="M1.5 1.5h7m0 0v7m0-7L1.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .case-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    position: relative;
  }
  .case-card:hover {
    transform: translateY(-5px);
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.16),
      0 24px 48px -8px rgba(0,0,0,0.65),
      0 0 36px -6px var(--glow, transparent);
  }
  .case-card:hover .card-arrow {
    background: rgba(255,255,255,0.06);
    transform: translate(2px, -2px);
  }
  .case-card:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }
</style>
