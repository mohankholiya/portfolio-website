---
import { competencies } from "../content/site";

const svgIcons = [
  // 1. Strategic Sourcing & Category Management — concentric target rings
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/></svg>`,
  // 2. Supplier Development & Performance — network nodes
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><path d="M12 7v3.5M12 10.5l-5.1 6.6M12 10.5l5.1 6.6"/></svg>`,
  // 3. Contract Strategy & Negotiation — document with lines
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
  // 4. Supply Chain Risk & Resilience — shield check
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9,12 11,14 15,10"/></svg>`,
  // 5. Digital Procurement & Analytics — trending line
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22,7 13.5,15.5 8.5,10.5 2,17"/><polyline points="16,7 22,7 22,13"/></svg>`,
  // 6. Spend Analytics & Cost Modelling — bar chart ascending
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>`,
];

const cardColors = [
  { gradient: "linear-gradient(135deg, rgba(77,158,255,0.18), rgba(77,158,255,0.04))", border: "rgba(77,158,255,0.2)", hoverBorder: "rgba(77,158,255,0.4)" },
  { gradient: "linear-gradient(135deg, rgba(62,207,142,0.18), rgba(62,207,142,0.04))", border: "rgba(62,207,142,0.2)", hoverBorder: "rgba(62,207,142,0.4)" },
  { gradient: "linear-gradient(135deg, rgba(249,115,22,0.18), rgba(249,115,22,0.04))",  border: "rgba(249,115,22,0.2)",  hoverBorder: "rgba(249,115,22,0.4)" },
  { gradient: "linear-gradient(135deg, rgba(139,92,246,0.18), rgba(139,92,246,0.04))", border: "rgba(139,92,246,0.2)", hoverBorder: "rgba(139,92,246,0.4)" },
  { gradient: "linear-gradient(135deg, rgba(236,72,153,0.18), rgba(236,72,153,0.04))", border: "rgba(236,72,153,0.2)", hoverBorder: "rgba(236,72,153,0.4)" },
  { gradient: "linear-gradient(135deg, rgba(6,182,212,0.18), rgba(6,182,212,0.04))",   border: "rgba(6,182,212,0.2)",   hoverBorder: "rgba(6,182,212,0.4)" },
];
---

<section
  id="competencies"
  aria-labelledby="competencies-heading"
  class="section"
  style="background:var(--color-canvas-soft);"
>
  <div class="container">

    <!-- Header -->
    <div style="max-width:560px; margin-bottom:48px;">
      <p class="t-caption-mono reveal" style="
        color:var(--color-mute);
        text-transform:uppercase;
        letter-spacing:0.08em;
        margin:0 0 16px;
      ">Core Competencies</p>

      <h2 id="competencies-heading" class="t-display-lg reveal" style="
        color:var(--color-ink); margin:0 0 16px;
        animation-delay:0.07s;
      ">
        Six functional areas. One integrated approach.
      </h2>

      <p class="t-body-md reveal" style="color:var(--color-body-text); margin:0; animation-delay:0.12s;">
        Across 16 years the work has covered the full procurement spectrum — from upstream strategy
        to delivery and digital capability uplift.
      </p>
    </div>

    <!-- Competency grid -->
    <div style="
      display:grid;
      grid-template-columns:repeat(auto-fill, minmax(min(100%, 320px), 1fr));
      gap:12px;
    ">
      {competencies.map((c, i) => (
        <div
          class="comp-card reveal shadow-l2"
          style={`
            background:var(--color-canvas);
            border-radius:var(--radius-md);
            padding:24px;
            animation-delay:${(i % 3) * 0.06 + Math.floor(i / 3) * 0.1}s;
            border:1px solid ${cardColors[i].border};
            transition:transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
            position:relative;
            overflow:hidden;
          `}
          data-hover-border={cardColors[i].hoverBorder}
        >
          <!-- Icon -->
          <div style={`
            width:48px; height:48px;
            background:${cardColors[i].gradient};
            border-radius:var(--radius-sm);
            display:flex; align-items:center; justify-content:center;
            color:var(--color-ink);
            margin-bottom:16px;
            flex-shrink:0;
          `}>
            <Fragment set:html={svgIcons[i]} />
          </div>

          <!-- Title -->
          <h3 class="t-body-sm-strong" style="color:var(--color-ink); margin:0 0 8px;">
            {c.title}
          </h3>

          <!-- Description -->
          <p class="t-body-sm" style="color:var(--color-body-text); margin:0; line-height:1.6;">
            {c.description}
          </p>

          <!-- Bottom accent line on hover -->
          <div class="comp-accent-line" aria-hidden="true" style="
            position:absolute; bottom:0; left:24px; right:24px;
            height:1px;
            background:linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
            opacity:0;
            transition:opacity 0.2s ease;
          "></div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .comp-card:hover {
    transform: translateY(-4px);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1), 0px 12px 32px -6px rgba(0,0,0,0.6) !important;
  }
  .comp-card:hover .comp-accent-line {
    opacity: 1 !important;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.comp-card').forEach(card => {
    const hoverBorder = card.dataset.hoverBorder ?? 'rgba(255,255,255,0.2)';
    const defaultBorder = card.style.borderColor;
    card.addEventListener('mouseenter', () => { card.style.borderColor = hoverBorder; });
    card.addEventListener('mouseleave', () => { card.style.borderColor = defaultBorder; });
  });
</script>
