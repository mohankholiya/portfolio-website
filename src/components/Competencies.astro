---
import { competencies } from "../content/site";

const icons = ["◈", "◎", "◆", "◉", "◇", "●"];

const cardColors = [
  { gradient: "linear-gradient(135deg, rgba(77,158,255,0.18), rgba(77,158,255,0.04))", border: "rgba(77,158,255,0.2)", hoverBorder: "rgba(77,158,255,0.4)" },
  { gradient: "linear-gradient(135deg, rgba(62,207,142,0.18), rgba(62,207,142,0.04))", border: "rgba(62,207,142,0.2)", hoverBorder: "rgba(62,207,142,0.4)" },
  { gradient: "linear-gradient(135deg, rgba(249,115,22,0.18), rgba(249,115,22,0.04))",  border: "rgba(249,115,22,0.2)",  hoverBorder: "rgba(249,115,22,0.4)" },
  { gradient: "linear-gradient(135deg, rgba(139,92,246,0.18), rgba(139,92,246,0.04))", border: "rgba(139,92,246,0.2)", hoverBorder: "rgba(139,92,246,0.4)" },
  { gradient: "linear-gradient(135deg, rgba(236,72,153,0.18), rgba(236,72,153,0.04))", border: "rgba(236,72,153,0.2)", hoverBorder: "rgba(236,72,153,0.4)" },
  { gradient: "linear-gradient(135deg, rgba(6,182,212,0.18), rgba(6,182,212,0.04))",   border: "rgba(6,182,212,0.2)",   hoverBorder: "rgba(6,182,212,0.4)" },
];
---

<section
  id="competencies"
  aria-labelledby="competencies-heading"
  class="section"
  style="background:var(--color-canvas-soft);"
>
  <div class="container">

    <!-- Header -->
    <div style="max-width:560px; margin-bottom:48px;">
      <p class="t-caption-mono reveal" style="
        color:var(--color-mute);
        text-transform:uppercase;
        letter-spacing:0.08em;
        margin:0 0 16px;
      ">Core Competencies</p>

      <h2 id="competencies-heading" class="t-display-lg reveal" style="
        color:var(--color-ink); margin:0 0 16px;
        animation-delay:0.07s;
      ">
        Six functional areas. One integrated approach.
      </h2>

      <p class="t-body-md reveal" style="color:var(--color-body-text); margin:0; animation-delay:0.12s;">
        Across 16 years the work has covered the full procurement spectrum — from upstream strategy
        to delivery and digital capability uplift.
      </p>
    </div>

    <!-- Competency grid -->
    <div style="
      display:grid;
      grid-template-columns:repeat(auto-fill, minmax(min(100%, 320px), 1fr));
      gap:12px;
    ">
      {competencies.map((c, i) => (
        <div
          class="comp-card reveal shadow-l2"
          style={`
            background:var(--color-canvas);
            border-radius:var(--radius-md);
            padding:24px;
            animation-delay:${(i % 3) * 0.06 + Math.floor(i / 3) * 0.1}s;
            border:1px solid ${cardColors[i].border};
            transition:transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
            position:relative;
            overflow:hidden;
          `}
          data-hover-border={cardColors[i].hoverBorder}
        >
          <!-- Icon -->
          <div style={`
            width:48px; height:48px;
            background:${cardColors[i].gradient};
            border-radius:var(--radius-sm);
            display:flex; align-items:center; justify-content:center;
            font-size:18px; color:var(--color-ink);
            margin-bottom:16px;
            flex-shrink:0;
          `} aria-hidden="true">{icons[i]}</div>

          <!-- Title -->
          <h3 class="t-body-sm-strong" style="color:var(--color-ink); margin:0 0 8px;">
            {c.title}
          </h3>

          <!-- Description -->
          <p class="t-body-sm" style="color:var(--color-body-text); margin:0; line-height:1.6;">
            {c.description}
          </p>

          <!-- Bottom accent line on hover -->
          <div class="comp-accent-line" aria-hidden="true" style="
            position:absolute; bottom:0; left:24px; right:24px;
            height:1px;
            background:linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
            opacity:0;
            transition:opacity 0.2s ease;
          "></div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .comp-card:hover {
    transform: translateY(-4px);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1), 0px 12px 32px -6px rgba(0,0,0,0.6) !important;
  }
  .comp-card:hover .comp-accent-line {
    opacity: 1 !important;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.comp-card').forEach(card => {
    const hoverBorder = card.dataset.hoverBorder ?? 'rgba(255,255,255,0.2)';
    const defaultBorder = card.style.borderColor;
    card.addEventListener('mouseenter', () => { card.style.borderColor = hoverBorder; });
    card.addEventListener('mouseleave', () => { card.style.borderColor = defaultBorder; });
  });
</script>
