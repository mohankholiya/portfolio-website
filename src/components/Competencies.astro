---
import { competencies } from "../content/site";

// Icons reordered to match the competency list; rendered monochrome.
const svgIcons = [
  // 1. Strategic Sourcing & Category Management — concentric target
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="8.5"/><circle cx="12" cy="12" r="4.5"/><circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"/></svg>`,
  // 2. Contract Strategy & Negotiation — document
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2.5H6.5A1.5 1.5 0 005 4v16A1.5 1.5 0 006.5 21.5h11A1.5 1.5 0 0019 20V7.5z"/><polyline points="14 2.5 14 7.5 19 7.5"/><line x1="8.5" y1="12" x2="15.5" y2="12"/><line x1="8.5" y1="15.5" x2="15.5" y2="15.5"/><line x1="8.5" y1="9" x2="10.5" y2="9"/></svg>`,
  // 3. Supplier Development & Performance — network nodes
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><path d="M12 7v3.2M11 11l-5 6M13 11l5 6"/></svg>`,
  // 4. Capital Benchmarking & Cost Modelling — ascending bars
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="20" x2="20" y2="20"/><line x1="8" y1="20" x2="8" y2="14"/><line x1="12.5" y1="20" x2="12.5" y2="9"/><line x1="17" y1="20" x2="17" y2="4"/></svg>`,
  // 5. Supply Chain Risk & Resilience — shield check
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21.5s7.5-3.8 7.5-9.5V5.2L12 2.5 4.5 5.2V12c0 5.7 7.5 9.5 7.5 9.5z"/><polyline points="9 11.8 11.2 14 15.2 10"/></svg>`,
  // 6. Digital Procurement & Spend Analytics — trending line
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3.5 16.5 9 11 13 14.5 20.5 6.5"/><polyline points="15 6.5 20.5 6.5 20.5 12"/></svg>`,
];
---

<section
  id="competencies"
  aria-labelledby="competencies-heading"
  class="section"
  style="background:var(--color-surface-tint); position:relative;"
>
  <div class="container">

    <!-- Header -->
    <div class="reveal" style="max-width:600px; margin-bottom:40px;">
      <div class="section-eyebrow">
        <p class="t-eyebrow" style="margin:0;">Core Competencies</p>
      </div>

      <h2 id="competencies-heading" class="t-display-lg" style="margin:0 0 14px; animation-delay:0.07s;">
        Six functional areas. One integrated approach.
      </h2>

      <p class="t-body-md" style="margin:0; animation-delay:0.12s;">
        The full procurement spectrum &mdash; from upstream category strategy through
        contracting, supplier governance, and digital analytics.
      </p>
    </div>

    <!-- Competency grid -->
    <div class="reveal comp-grid" style="animation-delay:0.16s;">
      {competencies.map((c, i) => (
        <article class="comp-card">
          <div class="comp-card__top">
            <span class="comp-card__icon" aria-hidden="true">
              <Fragment set:html={svgIcons[i]} />
            </span>
            <span class="comp-card__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <h3 class="comp-card__title">{c.title}</h3>
          <p class="comp-card__desc">{c.description}</p>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .comp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: 1px;
    background: var(--color-hairline);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .comp-card {
    background: var(--color-surface);
    padding: 26px 24px;
    transition: background 0.2s ease;
    position: relative;
  }
  .comp-card:hover { background: #fff; }
  .comp-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .comp-card__icon {
    width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
    color: var(--color-accent);
    background: var(--color-accent-tint);
    border-radius: var(--radius-sm);
  }
  .comp-card__icon :global(svg) { width: 19px; height: 19px; display: block; }
  .comp-card__num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-faint);
    letter-spacing: 0.08em;
  }
  .comp-card__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16.5px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0 0 8px;
  }
  .comp-card__desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-body);
    margin: 0;
  }
  @media (min-width: 960px) {
    .comp-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
