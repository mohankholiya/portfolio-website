---
import { siteConfig, heroStats } from "../content/site";
---

<section
  id="hero"
  aria-labelledby="hero-headline"
  style="
    position:relative;
    background:var(--color-canvas-soft);
    padding: 160px 24px 96px;
    overflow:hidden;
  "
>
  <!-- Mesh gradient backdrop -->
  <div aria-hidden="true" style="
    position:absolute; inset:0; pointer-events:none; z-index:0;
    background:
      radial-gradient(ellipse 90%  50% at 50% -15%, rgba(0,112,243,0.28) 0%, transparent 60%),
      radial-gradient(ellipse 70%  45% at 85%  25%, rgba(121,40,202,0.13) 0%, transparent 55%),
      radial-gradient(ellipse 80%  55% at 10%  35%, rgba(0,223,216,0.09) 0%, transparent 55%),
      radial-gradient(ellipse 60%  40% at 55%  85%, rgba(249,203,40,0.05) 0%, transparent 60%);
  "></div>

  <!-- Dot grid texture -->
  <div class="hero-dot-grid" aria-hidden="true"></div>

  <!-- Cursor spotlight — follows mouse, illuminates the hero like a blueprint reader -->
  <div
    id="hero-spotlight"
    aria-hidden="true"
    style="
      position:absolute; inset:0; pointer-events:none; z-index:1;
      opacity:0;
      transition:opacity 0.9s ease;
      background:radial-gradient(
        circle 420px at var(--cx, 50%) var(--cy, 50%),
        rgba(77,158,255,0.11) 0%,
        rgba(0,112,243,0.07) 35%,
        transparent 70%
      );
    "
  ></div>

  <div class="container" style="position:relative; z-index:2;">

    <!-- Eyebrow -->
    <div class="hero-in" style="--d:0s; margin-bottom:24px;">
      <span class="t-caption-mono badge" style="
        background:var(--color-canvas-soft-2);
        color:var(--color-body-text);
        border:1px solid var(--color-hairline);
        text-transform:uppercase;
        letter-spacing:0.08em;
      ">
        Procurement &amp; Supply Chain
      </span>
    </div>

    <!-- Headline -->
    <h1
      id="hero-headline"
      class="t-display-xl gradient-text hero-in"
      style="
        max-width:820px;
        margin:0 0 24px;
        --d:0.1s;
      "
    >
      Delivering measurable cost-out and resilience.
    </h1>

    <!-- Lead -->
    <p
      class="t-body-lg hero-in"
      style="
        max-width:540px;
        color:var(--color-body-text);
        margin:0 0 40px;
        --d:0.2s;
      "
    >
      {siteConfig.positioning}
    </p>

    <!-- CTAs -->
    <div
      class="hero-in"
      style="
        display:flex; flex-wrap:wrap; gap:12px; margin-bottom:64px;
        --d:0.3s;
      "
    >
      <a href="#case-studies" class="btn-primary t-button-lg">
        View track record
      </a>
      <a href={`mailto:${siteConfig.email}`} class="btn-secondary t-button-lg">
        Discuss an engagement
      </a>
    </div>

    <!-- Divider — expands left-to-right -->
    <div
      class="hero-line-in"
      style="
        border-top:1px solid var(--color-hairline);
        margin-bottom:40px;
        --d:0.38s;
      "
    ></div>

    <!-- Stats row — each stat in an elevated card -->
    <dl
      class="hero-in hero-stats-row"
      style="--d:0.46s;"
    >
      {heroStats.map(stat => (
        <div class="stat-card shadow-l2">
          <dt class="t-caption-mono" style="color:var(--color-mute); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:6px;">
            {stat.label}
          </dt>
          <dd
            class="t-display-md"
            style="color:var(--color-ink); margin:0;"
            data-counter={stat.numeric}
            data-suffix={stat.suffix}
          >
            {stat.display}
          </dd>
        </div>
      ))}

      <!-- Sectors card -->
      <div class="stat-card shadow-l2">
        <dt class="t-caption-mono" style="color:var(--color-mute); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:8px;">
          Sectors
        </dt>
        <dd style="display:flex; flex-wrap:wrap; gap:6px; margin:0;">
          {["Energy", "Oil & Gas", "Utilities", "Telecom"].map(s => (
            <span class="badge t-caption-mono" style="font-size:11px;">{s}</span>
          ))}
        </dd>
      </div>
    </dl>

  </div>

  <!-- Scroll indicator -->
  <div aria-hidden="true" style="
    position:absolute; bottom:32px; left:50%;
    transform:translateX(-50%);
    z-index:2;
  ">
    <a
      href="#about"
      class="scroll-indicator hero-in"
      aria-label="Scroll to About"
      style="color:rgba(255,255,255,0.35); text-decoration:none; display:inline-flex; --d:0.6s;"
      tabindex="-1"
    >
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M5 9l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .hero-stats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .stat-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-md);
    padding: 16px 20px;
    min-width: 120px;
    transition: border-color 0.2s ease;
  }
  .stat-card:hover {
    border-color: rgba(255,255,255,0.18);
  }
</style>

<script>
  // ── Cursor spotlight ──────────────────────────────────────────────
  const hero = document.getElementById('hero');
  const spotlight = document.getElementById('hero-spotlight') as HTMLElement | null;

  if (hero && spotlight && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    hero.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width * 100).toFixed(2);
      const y = ((e.clientY - rect.top) / rect.height * 100).toFixed(2);
      spotlight.style.setProperty('--cx', x + '%');
      spotlight.style.setProperty('--cy', y + '%');
      spotlight.style.opacity = '1';
    }, { passive: true });

    hero.addEventListener('mouseleave', () => {
      spotlight.style.opacity = '0';
    });
  }

  // ── Counter animation ─────────────────────────────────────────────
  const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
  const counterObs = new IntersectionObserver(
    entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target as HTMLElement;
        const target = parseInt(el.dataset.counter ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const dur = 1200;
        const fps = 60;
        const step = target / (dur / (1000 / fps));
        let current = 0;
        const tick = () => {
          current = Math.min(current + step, target);
          el.textContent = Math.floor(current) + suffix;
          if (current < target) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        counterObs.unobserve(el);
      });
    },
    { threshold: 0.5 }
  );
  counters.forEach(el => counterObs.observe(el));
</script>
