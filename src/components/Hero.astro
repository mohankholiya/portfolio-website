---
import { siteConfig, heroStats } from "../content/site";
---

<section
  id="hero"
  aria-labelledby="hero-headline"
  style="
    position:relative;
    background:var(--color-canvas-soft);
    padding: 160px 24px 96px;
    overflow:hidden;
  "
>
  <!-- Mesh gradient backdrop — more vibrant on dark -->
  <div aria-hidden="true" style="
    position:absolute; inset:0; pointer-events:none;
    background:
      radial-gradient(ellipse 90%  50% at 50% -15%, rgba(0,112,243,0.30) 0%, transparent 60%),
      radial-gradient(ellipse 70%  45% at 85%  25%, rgba(121,40,202,0.14) 0%, transparent 55%),
      radial-gradient(ellipse 80%  55% at 10%  35%, rgba(0,223,216,0.10) 0%, transparent 55%),
      radial-gradient(ellipse 60%  40% at 55%  85%, rgba(249,203,40,0.06) 0%, transparent 60%);
  "></div>

  <div class="container" style="position:relative; z-index:1;">

    <!-- Eyebrow -->
    <div class="reveal" style="margin-bottom:24px;">
      <span class="t-caption-mono badge" style="
        background:var(--color-canvas-soft-2);
        color:var(--color-body-text);
        border:1px solid var(--color-hairline);
        text-transform:uppercase;
        letter-spacing:0.08em;
      ">
        Procurement &amp; Supply Chain
      </span>
    </div>

    <!-- Headline -->
    <h1
      id="hero-headline"
      class="t-display-xl gradient-text reveal"
      style="
        max-width:720px;
        margin:0 0 24px;
        animation-delay:0.07s;
      "
    >
      Delivering measurable cost-out and resilience.
    </h1>

    <!-- Lead -->
    <p
      class="t-body-lg reveal"
      style="
        max-width:540px;
        color:var(--color-body-text);
        margin:0 0 40px;
        animation-delay:0.14s;
      "
    >
      {siteConfig.positioning}
    </p>

    <!-- CTAs -->
    <div
      class="reveal"
      style="
        display:flex; flex-wrap:wrap; gap:12px; margin-bottom:64px;
        animation-delay:0.21s;
      "
    >
      <a href="#case-studies" class="btn-primary t-button-lg">
        View track record
      </a>
      <a href={`mailto:${siteConfig.email}`} class="btn-secondary t-button-lg">
        Discuss an engagement
      </a>
    </div>

    <!-- Divider -->
    <div
      class="reveal"
      style="
        border-top:1px solid var(--color-hairline);
        margin-bottom:40px;
        animation-delay:0.28s;
      "
    ></div>

    <!-- Stats row -->
    <dl
      class="reveal"
      style="
        display:flex; flex-wrap:wrap; gap:40px 48px;
        animation-delay:0.35s;
      "
    >
      {heroStats.map(stat => (
        <div>
          <dt
            class="t-caption-mono"
            style="color:var(--color-mute); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:6px;"
          >
            {stat.label}
          </dt>
          <dd
            class="t-display-md"
            style="color:var(--color-ink); margin:0;"
            data-counter={stat.numeric}
            data-suffix={stat.suffix}
          >
            {stat.display}
          </dd>
        </div>
      ))}

      <!-- Sectors badge cluster -->
      <div>
        <dt class="t-caption-mono" style="color:var(--color-mute); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:8px;">
          Sectors
        </dt>
        <dd style="display:flex; flex-wrap:wrap; gap:6px; margin:0;">
          {["Energy", "Oil & Gas", "Utilities", "Telecom"].map(s => (
            <span class="badge t-caption-mono" style="font-size:11px;">{s}</span>
          ))}
        </dd>
      </div>
    </dl>

  </div>

  <!-- Scroll indicator -->
  <div aria-hidden="true" style="
    position:absolute; bottom:32px; left:50%;
    transform:translateX(-50%);
    z-index:1;
  ">
    <a
      href="#about"
      class="scroll-indicator"
      aria-label="Scroll to About"
      style="color:rgba(255,255,255,0.4); text-decoration:none; display:inline-flex;"
      tabindex="-1"
    >
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M5 9l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</section>

<script>
  // Scroll reveal
  const reveals = document.querySelectorAll<HTMLElement>('.reveal');
  const revealObs = new IntersectionObserver(
    entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('is-visible');
          revealObs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  reveals.forEach(el => revealObs.observe(el));

  // Counter animation
  const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
  const counterObs = new IntersectionObserver(
    entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target as HTMLElement;
        const target = parseInt(el.dataset.counter ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const dur = 1200;
        const fps = 60;
        const step = target / (dur / (1000 / fps));
        let current = 0;
        const tick = () => {
          current = Math.min(current + step, target);
          el.textContent = Math.floor(current) + suffix;
          if (current < target) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        counterObs.unobserve(el);
      });
    },
    { threshold: 0.5 }
  );
  counters.forEach(el => counterObs.observe(el));
</script>
