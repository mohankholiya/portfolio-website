---
import { siteConfig, navLinks } from "../content/site";

const year = new Date().getFullYear();
---

<footer
  aria-label="Site footer"
  style="
    background:var(--color-canvas);
    border-top:1px solid var(--color-hairline);
    padding:40px 24px;
  "
>
  <div class="container">
    <div style="
      display:flex;
      flex-wrap:wrap;
      align-items:center;
      justify-content:space-between;
      gap:16px;
    ">

      <!-- Left: brand -->
      <div style="display:flex; align-items:center; gap:10px;">
        <span style="
          width:24px; height:24px;
          background:var(--color-ink);
          color:var(--color-on-ink);
          border-radius:4px;
          display:flex; align-items:center; justify-content:center;
          font-size:10px; font-weight:600; letter-spacing:-0.3px;
          flex-shrink:0;
        " aria-hidden="true">MK</span>
        <span class="t-caption-mono" style="color:var(--color-mute);">
          &copy; {year} Mohan Kholiya
        </span>
      </div>

      <!-- Center: nav links -->
      <nav aria-label="Footer navigation" style="display:flex; flex-wrap:wrap; gap:4px;">
        {navLinks.map(link => (
          <a href={link.href} class="footer-link t-body-sm">
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right: external links -->
      <div style="display:flex; align-items:center; gap:16px;">
        <a
          href={siteConfig.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-ext-link t-body-sm"
        >
          LinkedIn ↗
        </a>
        <a
          href={siteConfig.resumeUrl}
          download={siteConfig.resumeFileName}
          class="footer-ext-link t-body-sm"
        >
          Download résumé
        </a>
      </div>

    </div>
  </div>
</footer>
