---
import { siteConfig } from "../content/site";

const year = new Date().getFullYear();
---

<footer
  aria-label="Site footer"
  style="
    background:var(--color-canvas);
    border-top:1px solid var(--color-hairline);
    padding:40px 24px;
  "
>
  <div class="container">
    <div style="
      display:flex;
      flex-wrap:wrap;
      align-items:center;
      justify-content:space-between;
      gap:16px;
    ">

      <!-- Left: brand -->
      <div style="display:flex; align-items:center; gap:10px;">
        <span style="
          width:24px; height:24px;
          background:var(--color-ink);
          color:var(--color-on-ink);
          border-radius:4px;
          display:flex; align-items:center; justify-content:center;
          font-size:10px; font-weight:600; letter-spacing:-0.3px;
          flex-shrink:0;
        " aria-hidden="true">MK</span>
        <span class="t-caption-mono" style="color:var(--color-mute);">
          &copy; {year} Mohan Kholiya
        </span>
      </div>

      <!-- Center: nav links -->
      <nav aria-label="Footer navigation" style="display:flex; flex-wrap:wrap; gap:4px;">
        {[
          { href: "#about",         label: "About" },
          { href: "#case-studies",  label: "Case Studies" },
          { href: "#competencies",  label: "Competencies" },
          { href: "#credentials",   label: "Credentials" },
          { href: "#contact",       label: "Contact" },
        ].map(link => (
          <a
            href={link.href}
            class="t-body-sm"
            style="
              color:var(--color-body-text);
              text-decoration:none;
              padding:4px 10px;
              border-radius:var(--radius-full);
              transition:background 0.15s ease, color 0.15s ease;
            "
            onmouseover="this.style.background='var(--color-canvas-soft-2)'; this.style.color='var(--color-ink)';"
            onmouseout="this.style.background=''; this.style.color='var(--color-body-text)';"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right: external links -->
      <div style="display:flex; align-items:center; gap:12px;">
        <a
          href={siteConfig.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="t-body-sm"
          style="color:var(--color-body-text); text-decoration:none; transition:color 0.15s ease;"
          onmouseover="this.style.color='var(--color-ink)';"
          onmouseout="this.style.color='var(--color-body-text)';"
        >
          LinkedIn ↗
        </a>
        <a
          href={siteConfig.resumeUrl}
          download="Mohan_Kholiya_Resume.pdf"
          class="t-body-sm"
          style="color:var(--color-body-text); text-decoration:none; transition:color 0.15s ease;"
          onmouseover="this.style.color='var(--color-ink)';"
          onmouseout="this.style.color='var(--color-body-text)';"
        >
          Download résumé
        </a>
      </div>

    </div>
  </div>
</footer>
