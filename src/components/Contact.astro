---
import { siteConfig } from "../content/site";
---

<section
  id="contact"
  aria-labelledby="contact-heading"
  class="section"
  style="
    background:
      radial-gradient(ellipse 100% 80% at 50% 0%,   rgba(0,112,243,0.14) 0%, transparent 65%),
      radial-gradient(ellipse 70%  50% at 80%  80%,  rgba(121,40,202,0.09) 0%, transparent 60%),
      radial-gradient(ellipse 60%  40% at 10%  70%,  rgba(0,223,216,0.05) 0%, transparent 55%),
      #0d0d0d;
    border-top: 1px solid rgba(255,255,255,0.07);
  "
>
  <div class="container" style="max-width:680px; margin:0 auto;">

    <!-- Eyebrow -->
    <p class="t-caption-mono reveal" style="
      color:rgba(255,255,255,0.35);
      text-transform:uppercase;
      letter-spacing:0.08em;
      margin:0 0 24px;
      text-align:center;
    ">Get in touch</p>

    <!-- Headline -->
    <h2 id="contact-heading" class="t-display-xl reveal" style="
      color:#ededed;
      margin:0 0 20px;
      animation-delay:0.07s;
      text-align:center;
    ">
      Let's work together.
    </h2>

    <!-- Sub -->
    <p class="t-body-lg reveal" style="
      color:rgba(255,255,255,0.5);
      margin:0 0 48px;
      animation-delay:0.14s;
      text-align:center;
    ">
      Open to senior procurement and supply chain leadership roles and consulting engagements
      globally. Response within 24 hours.
    </p>

    <!-- Contact form -->
    <!-- Web3Forms: get your free access key at web3forms.com (enter your email, takes ~60s) -->
    <!-- Replace YOUR_ACCESS_KEY below with the key sent to mohan.kholiya@gmail.com -->
    <form
      id="contact-form"
      class="reveal"
      style="
        display:flex; flex-direction:column; gap:16px;
        margin-bottom:40px;
        animation-delay:0.18s;
      "
      novalidate
    >
      <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY" />
      <input type="hidden" name="subject" value="Portfolio enquiry — mohankholiya.co.in" />
      <input type="checkbox" name="botcheck" style="display:none;" aria-hidden="true" />

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;" class="form-row">
        <div>
          <label for="cf-name" class="t-body-sm-strong" style="display:block; color:#ededed; margin-bottom:6px;">Name</label>
          <input
            type="text"
            id="cf-name"
            name="name"
            required
            class="form-input"
            placeholder="Your name"
            autocomplete="name"
          />
        </div>
        <div>
          <label for="cf-email" class="t-body-sm-strong" style="display:block; color:#ededed; margin-bottom:6px;">Email</label>
          <input
            type="email"
            id="cf-email"
            name="email"
            required
            class="form-input"
            placeholder="your@email.com"
            autocomplete="email"
          />
        </div>
      </div>

      <div>
        <label for="cf-message" class="t-body-sm-strong" style="display:block; color:#ededed; margin-bottom:6px;">Message</label>
        <textarea
          id="cf-message"
          name="message"
          required
          rows="4"
          class="form-input"
          placeholder="Tell me about the role or engagement..."
        ></textarea>
      </div>

      <button
        type="submit"
        id="cf-submit"
        class="btn-primary t-button-lg"
        style="justify-content:center;"
      >
        Send Message
      </button>

      <p
        id="form-status"
        role="status"
        aria-live="polite"
        class="t-body-sm"
        style="display:none; text-align:center; margin:0;"
      ></p>
    </form>

    <!-- Divider with label -->
    <div class="reveal" style="
      display:flex; align-items:center; gap:12px;
      margin-bottom:32px;
      animation-delay:0.22s;
    ">
      <div style="flex:1; height:1px; background:rgba(255,255,255,0.07);"></div>
      <span class="t-caption-mono" style="color:rgba(255,255,255,0.25);">or reach out directly</span>
      <div style="flex:1; height:1px; background:rgba(255,255,255,0.07);"></div>
    </div>

    <!-- Direct CTAs -->
    <div class="reveal" style="
      display:flex; flex-wrap:wrap; gap:12px; justify-content:center;
      margin-bottom:40px;
      animation-delay:0.26s;
    ">
      <a
        href={`mailto:${siteConfig.email}`}
        style="
          display:inline-flex; align-items:center; gap:8px;
          background:#ededed; color:#0a0a0a;
          border-radius:var(--radius-pill);
          padding:0 28px; height:48px;
          font-size:16px; font-weight:500; font-family:var(--font-sans);
          text-decoration:none;
          transition:opacity 0.15s ease, transform 0.15s ease;
        "
        onmouseover="this.style.opacity='0.88';"
        onmouseout="this.style.opacity='1';"
        onmousedown="this.style.transform='scale(0.98)';"
        onmouseup="this.style.transform='';"
      >
        Email Mohan
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 12L12 2M12 2H6M12 2V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <a
        href={siteConfig.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        style="
          display:inline-flex; align-items:center; gap:8px;
          background:transparent; color:#ededed;
          border-radius:var(--radius-pill);
          border:1px solid rgba(255,255,255,0.15);
          padding:0 28px; height:48px;
          font-size:16px; font-weight:500; font-family:var(--font-sans);
          text-decoration:none;
          transition:border-color 0.15s ease, background 0.15s ease;
        "
        onmouseover="this.style.borderColor='rgba(255,255,255,0.32)'; this.style.background='rgba(255,255,255,0.05)';"
        onmouseout="this.style.borderColor='rgba(255,255,255,0.15)'; this.style.background='transparent';"
      >
        LinkedIn ↗
      </a>
    </div>

    <!-- Divider -->
    <div class="reveal" style="
      border-top:1px solid rgba(255,255,255,0.07);
      margin-bottom:32px;
      animation-delay:0.30s;
    "></div>

    <!-- Pathway chips -->
    <div class="reveal" style="
      display:flex; flex-wrap:wrap; gap:8px; justify-content:center;
      animation-delay:0.34s;
    ">
      <span style="
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(255,255,255,0.05);
        color:rgba(255,255,255,0.65);
        border:1px solid rgba(255,255,255,0.09);
        border-radius:var(--radius-full);
        padding:0 14px; height:30px;
        font-size:13px; font-weight:400; font-family:var(--font-sans);
      ">
        <span aria-hidden="true" style="width:6px;height:6px;border-radius:50%;background:var(--color-success);flex-shrink:0;"></span>
        Open to senior leadership roles
      </span>
      <span style="
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(255,255,255,0.05);
        color:rgba(255,255,255,0.65);
        border:1px solid rgba(255,255,255,0.09);
        border-radius:var(--radius-full);
        padding:0 14px; height:30px;
        font-size:13px; font-weight:400; font-family:var(--font-sans);
      ">
        <span aria-hidden="true" style="width:6px;height:6px;border-radius:50%;background:var(--color-link);flex-shrink:0;"></span>
        Available for consulting engagements
      </span>
    </div>

  </div>
</section>

<style>
  @media (max-width: 560px) {
    .form-row {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLElement | null;
  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !status) return;

    const data = Object.fromEntries(new FormData(form));

    submitBtn.textContent = 'Sending…';
    submitBtn.disabled = true;

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();

      if (json.success) {
        status.textContent = '✓ Message sent — I\'ll respond within 24 hours.';
        status.style.color = 'var(--color-success)';
        status.style.display = 'block';
        form.reset();
      } else {
        throw new Error('failed');
      }
    } catch {
      status.textContent = 'Something went wrong. Please email me directly at mohan.kholiya@gmail.com';
      status.style.color = 'var(--color-error)';
      status.style.display = 'block';
    } finally {
      submitBtn.textContent = 'Send Message';
      submitBtn.disabled = false;
    }
  });
</script>
