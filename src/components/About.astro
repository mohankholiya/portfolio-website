---
import { siteConfig } from "../content/site";
---

<section
  id="about"
  aria-labelledby="about-heading"
  class="section"
  style="background:var(--color-canvas-soft);"
>
  <div class="container">

    <!-- Section eyebrow -->
    <p class="t-caption-mono reveal" style="
      color:var(--color-mute);
      text-transform:uppercase;
      letter-spacing:0.08em;
      margin:0 0 16px;
    ">About</p>

    <!-- Two-column layout -->
    <div style="
      display:grid;
      grid-template-columns: 1fr;
      gap:48px;
      align-items:start;
    " class="about-grid">

      <!-- Left: headshot -->
      <div class="reveal headshot-col" style="display:flex; justify-content:flex-start;">
        <div style="
          width:200px; height:200px;
          border-radius:9999px;
          box-shadow:0 0 0 2px var(--color-link), 0 8px 40px rgba(77,158,255,0.25);
          overflow:hidden;
          flex-shrink:0;
        ">
          <img
            src="/images/headshot.jpeg"
            alt="Mohan Kholiya — Procurement &amp; Supply Chain Leader"
            width="200"
            height="200"
            loading="eager"
            decoding="async"
            style="width:100%; height:100%; object-fit:cover; display:block;"
          />
        </div>
      </div>

      <!-- Right: copy -->
      <div>
        <h2 id="about-heading" class="t-display-lg reveal" style="color:var(--color-ink); margin:0 0 20px;">
          Procurement leader with a track record in energy, utilities, and telecom.
        </h2>

        <p class="t-body-lg reveal" style="color:var(--color-body-text); margin:0 0 16px; animation-delay:0.07s;">
          I have spent 16+ years at the intersection of strategic procurement and operational delivery —
          first in global management consulting, then in senior in-house category roles across
          major energy operators, utilities, and telecom businesses.
        </p>

        <p class="t-body-md reveal" style="color:var(--color-body-text); margin:0 0 32px; animation-delay:0.12s;">
          My work sits at the point where supplier strategy meets real business outcomes: cost reduction
          programmes that hold, supplier bases that perform under pressure, and procurement functions
          rebuilt for scale. I have led category strategy in upstream O&amp;G, downstream energy,
          regulated utilities, and tier-1 telecom — across the UK, North America, Middle East, and India.
        </p>

        <!-- Key points -->
        <ul class="reveal" style="
          list-style:none; margin:0; padding:0;
          display:flex; flex-direction:column; gap:12px;
          animation-delay:0.17s;
        ">
          {[
            "Global consulting advisory across E&P, refining, utilities, and telecom",
            "In-house category ownership: drilling, completion, capex, indirect spend",
            "Track record in digital procurement and supplier risk programme design",
            "Available for senior leadership roles and consulting engagements globally",
          ].map(point => (
            <li style="display:flex; gap:10px; align-items:flex-start;">
              <span aria-hidden="true" style="
                color:var(--color-link);
                font-size:16px;
                line-height:20px;
                margin-top:2px;
                flex-shrink:0;
              ">—</span>
              <span class="t-body-sm" style="color:var(--color-body-text);">{point}</span>
            </li>
          ))}
        </ul>

        <!-- Dual-pathway chips -->
        <div class="reveal" style="
          display:flex; flex-wrap:wrap; gap:8px; margin-top:32px;
          animation-delay:0.22s;
        ">
          <span style="
            display:inline-flex; align-items:center; gap:6px;
            background:var(--color-link-bg-soft);
            color:var(--color-link-deep);
            border-radius:var(--radius-full);
            padding:0 12px; height:28px;
            font-size:12px; font-weight:500;
          ">
            <span aria-hidden="true" style="width:6px;height:6px;border-radius:50%;background:var(--color-link);flex-shrink:0;"></span>
            Open to senior leadership roles
          </span>
          <span style="
            display:inline-flex; align-items:center; gap:6px;
            background:var(--color-canvas-soft-2);
            color:var(--color-body-text);
            border-radius:var(--radius-full);
            border:1px solid var(--color-hairline);
            padding:0 12px; height:28px;
            font-size:12px; font-weight:500;
          ">
            <span aria-hidden="true" style="width:6px;height:6px;border-radius:50%;background:var(--color-hairline-strong);flex-shrink:0;"></span>
            Available for consulting engagements
          </span>
        </div>

        <!-- Quick links -->
        <div class="reveal" style="display:flex; gap:12px; margin-top:24px; animation-delay:0.27s;">
          <a href={`mailto:${siteConfig.email}`} class="btn-primary-sm t-button-sm">
            Email Mohan
          </a>
          <a
            href={siteConfig.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary-sm t-button-sm"
          >
            LinkedIn ↗
          </a>
          <a href={siteConfig.resumeUrl} download class="btn-secondary-sm t-button-sm">
            Download résumé
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @media (min-width: 760px) {
    .about-grid {
      grid-template-columns: auto 1fr !important;
    }
    .headshot-col {
      justify-content: flex-end !important;
      padding-right: 24px;
    }
  }
</style>
